import psutil
import time
import matplotlib.pyplot as plt
import matplotlib.animation as animation
from collections import deque
import os
import matplotlib.gridspec as gridspec

# =========================
# Config
# =========================
HISTORY = 100            # number of samples shown
INTERVAL = 0.5          # seconds
N_CORES = psutil.cpu_count(logical=True)

# =========================
# Dark theme
# =========================
plt.style.use('dark_background')

# Generate a color per core from a colormap
CMAP = plt.cm.get_cmap('tab20', N_CORES)
CORE_COLORS = [CMAP(i) for i in range(N_CORES)]

# =========================
# Helpers
# =========================
def get_freqs():
    freqs = []
    max_freqs = []

    for i in range(N_CORES):
        base = f"/sys/devices/system/cpu/cpu{i}/cpufreq"
        try:
            with open(os.path.join(base, "scaling_cur_freq")) as f:
                cur = float(f.read().strip()) / 1e6  # kHz -> GHz
            with open(os.path.join(base, "cpuinfo_max_freq")) as f:
                maxf = float(f.read().strip()) / 1e6
        except:
            # fallback if cpufreq not available
            f = psutil.cpu_freq(percpu=True)[i]
            cur = f.current / 1000.0
            maxf = f.max / 1000.0 if f.max else cur

        freqs.append(cur)
        max_freqs.append(maxf)

    return freqs, max_freqs


# =========================
# Data buffers
# =========================
util_history = [deque([0]*HISTORY, maxlen=HISTORY) for _ in range(N_CORES)]
eff_history = [deque([0]*HISTORY, maxlen=HISTORY) for _ in range(N_CORES)]
freq_total_history = deque([0]*HISTORY, maxlen=HISTORY)

# =========================
# Plot setup — graph on top, key panel below
# =========================
fig = plt.figure(figsize=(12, 8))
gs = gridspec.GridSpec(2, 1, height_ratios=[3, 1], hspace=0.3)
ax = fig.add_subplot(gs[0])
ax_key = fig.add_subplot(gs[1])

x = list(range(HISTORY))

# =========================
# Update loop
# =========================
def update(frame):
    utils = psutil.cpu_percent(percpu=True)
    freqs, max_freqs = get_freqs()

    eff_values = []
    total_freq = sum(freqs)
    total_max = sum(max_freqs)

    # compute effective utilization (in GHz per core)
    for i in range(N_CORES):
        util = utils[i] / 100.0
        eff = util * freqs[i]  # GHz contributed by this core

        util_history[i].append(util)
        eff_history[i].append(eff)
        eff_values.append(eff)

    freq_total_history.append(total_freq)

    # =========================
    # Graph
    # =========================
    ax.clear()

    # stacked effective usage
    stack_data = [list(eff_history[i]) for i in range(N_CORES)]
    ax.stackplot(x, stack_data, colors=CORE_COLORS)

    # frequency line
    ax.plot(x, list(freq_total_history), color='white', linewidth=2,
            linestyle='--', label="Total Freq (GHz)")

    ax.set_ylim(0, total_max)
    ax.set_title("CPU Effective Throughput (Utilization × Frequency)", fontsize=13)
    ax.set_ylabel("GHz (effective)")
    ax.set_xlabel("Time")
    ax.legend(loc="upper left", fontsize=8)

    # =========================
    # Key panel
    # =========================
    ax_key.clear()
    ax_key.set_xlim(0, 1)
    ax_key.set_ylim(0, 1)
    ax_key.axis('off')

    # layout: arrange cores in a grid
    cols = min(8, N_CORES)
    rows = (N_CORES + cols - 1) // cols
    row_height = 0.7 / max(rows, 1)
    col_width = 1.0 / cols

    for i in range(N_CORES):
        r = i // cols
        c = i % cols
        x_pos = c * col_width + 0.01
        y_pos = 1.0 - 0.08 - r * row_height

        # color swatch
        ax_key.add_patch(plt.Rectangle(
            (x_pos, y_pos - 0.03), 0.015, 0.04,
            facecolor=CORE_COLORS[i], edgecolor='white', linewidth=0.5,
            transform=ax_key.transAxes, clip_on=False))

        ax_key.text(x_pos + 0.02, y_pos, f"CPU{i}: {utils[i]:5.1f}% @ {freqs[i]:.2f} GHz",
                    fontsize=7, color='white', va='center',
                    transform=ax_key.transAxes, family='monospace')

    # totals row at the bottom of the key
    total_freq_percent = (total_freq / total_max * 100) if total_max > 0 else 0
    total_util = sum(utils) / N_CORES
    total_eff = total_util * total_freq_percent / 100.0  # effective utilization as a percentage of max

    y_totals = 1.0 - 0.08 - rows * row_height - 0.04
    ax_key.text(0.01, y_totals,
                f"Total CPU Utilization: {total_util:.1f}%    |    "
                f"Total Effective Utilization (freq-normalized): {total_eff:.1f}%    |    "
                f"Total Freq: {total_freq:.1f} / {total_max:.1f} GHz ({total_freq_percent:.1f}%)",
                fontsize=8, color='#00ffaa', va='center',
                transform=ax_key.transAxes, family='monospace',
                fontweight='bold')

# =========================
# Run animation
# =========================
ani = animation.FuncAnimation(fig, update, interval=INTERVAL*1000)

plt.tight_layout()
plt.show()